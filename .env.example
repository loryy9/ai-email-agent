# Copia questo file in .env e valorizza i campi necessari.
# cp .env.example .env

# =========================
# LLM / GROQ
# =========================
# Obbligatoria: chiave API Groq
GROQ_API_KEY=your_groq_api_key_here

# Modello principale (qualita)
LLM_MODEL=llama-3.3-70b-versatile

# Modello rapido usato dal routing opzionale
TRIAGE_MODEL=llama-3.1-8b-instant

# Abilita routing rapido/qualita (true/false)
ENABLE_MODEL_ROUTING=true

# =========================
# Embeddings
# =========================
EMBED_MODEL=BAAI/bge-m3
# true/false: normalizza i vettori embedding
EMBED_NORMALIZE=true

# =========================
# Retrieval (runtime)
# =========================
DOC_K=6
DOC_SCORE_MIN=0.35
STORICO_SCORE_MIN=0.72
STORICO_DOC_MARGIN=0.03

ERROR_K=3
ERROR_SCORE_MIN=0.45

# =========================
# Ingestion / populate_db
# =========================
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# true/false: se true, cancella chroma_db_local prima del popolamento (impostalo a true solo al primo popolamento poi metti false)
RESET_DB_ON_POPULATE=false
